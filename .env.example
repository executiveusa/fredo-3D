# FREDO 3D — root development defaults
# Safe to commit. Copy to .env.local only when local overrides are needed.
# The default frontend mode requires no private secrets.

NODE_ENV=development

# Integration modes
CONTENT_PROVIDER=static
PAYMENTS_PROVIDER=disabled
MERCH_PROVIDER=disabled
ASSISTANT_PROVIDER=local
ANALYTICS_PROVIDER=disabled
EMAIL_PROVIDER=disabled

# Public identity
NEXT_PUBLIC_SITE_NAME=FREDO 3D
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_SUPPORTED_LOCALES=es,en
NEXT_PUBLIC_WHATSAPP_NUMBER=56993838223

# Local/public URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public Payload read endpoint. Leave blank in static mode.
NEXT_PUBLIC_CONTENT_PUBLIC_URL=
