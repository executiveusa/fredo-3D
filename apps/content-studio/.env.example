# FREDO 3D — Payload CMS runtime environment template for VPS
# Safe to commit as a template. Copy to a protected VPS-only secret file before deployment.
# Never commit populated values.

NODE_ENV=production

# Canonical URLs
CONTENT_STUDIO_SITE_URL=https://content.YOUR-FREDO-DOMAIN.example
PUBLIC_WEB_URL=https://YOUR-FREDO-DOMAIN.example
CONTENT_STUDIO_ALLOWED_ORIGINS=https://YOUR-FREDO-DOMAIN.example

# Payload — generate unique strong values on the VPS
PAYLOAD_SECRET=GENERATE_A_LONG_RANDOM_SECRET
CONTENT_STUDIO_PREVIEW_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET

# PostgreSQL — use the same password value as the VPS infrastructure secret
DATABASE_URL=postgresql://fredo_content:CHANGE_ME@postgres:5432/fredo_content

# Agent/MCP — disabled at initial launch
CONTENT_STUDIO_MCP_ENABLED=false
CONTENT_STUDIO_MCP_KEY=GENERATE_ONLY_WHEN_MCP_IS_ENABLED

# Storage: local | s3
CONTENT_STUDIO_STORAGE_DRIVER=local
CONTENT_STUDIO_MEDIA_DIR=/data/media

# Optional S3-compatible storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Email — disabled until configured
EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Payments — disabled until connected
PAYMENTS_PROVIDER=disabled
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Merchandise — disabled until connected
MERCH_PROVIDER=disabled
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# Assistant/agent provider — local mode by default
ASSISTANT_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Operations/security
CONTENT_STUDIO_CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET
CONTENT_STUDIO_BACKUP_ENCRYPTION_KEY=GENERATE_OR_MANAGE_OUTSIDE_APP
LOG_LEVEL=info
