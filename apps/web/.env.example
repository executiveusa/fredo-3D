# FREDO 3D — Vercel frontend environment template
# Safe to commit. Keep public configuration only unless a future server-only variable is explicitly required.
# Never put private database, Payload admin, MCP, PayPal, Stripe, Printify, or AI secrets in NEXT_PUBLIC_* variables.

NODE_ENV=production

NEXT_PUBLIC_SITE_NAME=FREDO 3D
NEXT_PUBLIC_SITE_URL=https://YOUR-FREDO-DOMAIN.example
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_SUPPORTED_LOCALES=es,en
NEXT_PUBLIC_WHATSAPP_NUMBER=56993838223

# Content modes: static | payload
CONTENT_PROVIDER=static

# Intentionally public read API only. Leave blank until the VPS content backend is live.
NEXT_PUBLIC_CONTENT_PUBLIC_URL=

# Optional integrations remain disabled until explicitly connected.
PAYMENTS_PROVIDER=disabled
MERCH_PROVIDER=disabled
ASSISTANT_PROVIDER=local
ANALYTICS_PROVIDER=disabled
EMAIL_PROVIDER=disabled

# Future server-only Vercel variables, only if approved server-side features are added:
# CONTENT_PREVIEW_TOKEN=
# REVALIDATION_SECRET=
