# FREDO 3D — VPS infrastructure environment template
# Safe to commit as a template. Copy to infra/vps/.env on the VPS and chmod 600.
# Never commit the populated file.

# Domains
CONTENT_DOMAIN=content.YOUR-FREDO-DOMAIN.example
PUBLIC_WEB_URL=https://YOUR-FREDO-DOMAIN.example

# PostgreSQL
POSTGRES_DB=fredo_content
POSTGRES_USER=fredo_content
POSTGRES_PASSWORD=GENERATE_A_STRONG_RANDOM_PASSWORD

# Payload
PAYLOAD_SECRET=GENERATE_A_LONG_RANDOM_SECRET
CONTENT_STUDIO_PREVIEW_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET
CONTENT_STUDIO_CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET

# MCP — disabled initially
CONTENT_STUDIO_MCP_ENABLED=false
CONTENT_STUDIO_MCP_KEY=GENERATE_ONLY_WHEN_ENABLED

# Storage
CONTENT_STUDIO_STORAGE_DRIVER=local
CONTENT_STUDIO_MEDIA_DIR=/data/media

# Optional S3-compatible storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Future providers
PAYMENTS_PROVIDER=disabled
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

MERCH_PROVIDER=disabled
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

ASSISTANT_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Backups
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE=0 3 * * *
