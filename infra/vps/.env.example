# =============================================================================
# FREDO 3D — VPS infrastructure environment (template)
# -----------------------------------------------------------------------------
# Owner: THE PAULI EFFECT  |  Client: FREDO 3D  |  VPS: 31.220.58.212
#
# Safe to commit. Copy to /opt/the-pauli-effect/clients/fredo3d/config/.env
# on the VPS and `chmod 600`. NEVER commit the populated file.
#
# v1 architecture (this file): static-first Next.js + cms-hold only.
# Postgres/Payload variables are present but inert until apps/content-studio
# ships (v2). The compose file reads the * variables it needs; the rest are
# ignored harmlessly.
# =============================================================================

# ---- Identity (safe, public) ------------------------------------------------
NEXT_PUBLIC_SITE_NAME=FREDO 3D
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_SUPPORTED_LOCALES=es,en
NEXT_PUBLIC_WHATSAPP_NUMBER=56993838223
PUBLIC_WEB_URL=https://fredo3d.com
CONTENT_DOMAIN=cms.fredo3d.com

# ---- v1 integration modes (all disabled — matches the repo's zero-secret default)
CONTENT_PROVIDER=static
PAYMENTS_PROVIDER=disabled
MERCH_PROVIDER=disabled
ASSISTANT_PROVIDER=local
ANALYTICS_PROVIDER=disabled
EMAIL_PROVIDER=disabled

# ---- PostgreSQL (v2 — Payload). NOT USED in v1. -----------------------------
# Generate with: openssl rand -hex 24
POSTGRES_DB=fredo_content
POSTGRES_USER=fredo_content
POSTGRES_PASSWORD=GENERATE_A_STRONG_RANDOM_PASSWORD

# ---- Payload (v2). NOT USED in v1. -----------------------------------------
PAYLOAD_SECRET=GENERATE_A_LONG_RANDOM_SECRET
CONTENT_STUDIO_PREVIEW_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET
CONTENT_STUDIO_CRON_SECRET=GENERATE_A_LONG_RANDOM_SECRET
PAYLOAD_PUBLIC_SERVER_URL=https://cms.fredo3d.com
ALLOWED_ORIGINS=https://fredo3d.com,https://www.fredo3d.com

# ---- Storage ---------------------------------------------------------------
CONTENT_STUDIO_STORAGE_DRIVER=local
CONTENT_STUDIO_MEDIA_DIR=/data/fredo3d/media

# Optional S3-compatible storage (only if v2 needs it)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ---- DNS automation (used by dns-apply.sh) ---------------------------------
HOSTINGER_API_TOKEN=
FREDO_DOMAIN=fredo3d.com
FREDO_VPS_IPV4=31.220.58.212

# ---- Backups ---------------------------------------------------------------
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE=17 3 * * *

# ---- Future providers (kept disabled). Enable only after staging approval. --
# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Printify (merch)
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Assistant (only when explicitly enabled; ASSISTANT_PROVIDER=local by default)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
