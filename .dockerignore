# Root build context filter for apps/web/Dockerfile (build context = repo root).

# Node / build artifacts
**/node_modules
**/.next
**/.turbo
**/dist
**/build
**/out
**/coverage

# Logs
**/*.log
**/.npm
**/.eslintcache

# Secrets — never ship into an image
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
**/*.pem
**/*.key
**/secrets/

# Studio local evidence
.studio/logs/
.studio/rollback/
.studio/reports/

# VCS / editor / OS
.git
.gitignore
.gitattributes
.DS_Store
Thumbs.db
.vscode/
.idea/

# Not needed at runtime; keeps context small
docs/
design/
research/
artifacts/
content/masters/
**/README.md
